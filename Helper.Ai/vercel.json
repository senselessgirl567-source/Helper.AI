{
  "version": 2,
  "builds": [
    { "src": "api/app.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/app.py" }
  ],
  "env": {
    "SECRET_KEY": "@helperai_secret_key",
    "DATABASE_URL": "@helperai_database_url",
    "NEON_DATABASE_URL": "@helperai_neon_database_url",
    "GROQ_API_TOKEN": "@helperai_groq_api_token"
  }
}
